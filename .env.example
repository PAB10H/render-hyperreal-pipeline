# 🔗 LINKS DOS SEUS CHATS

# Link público do seu GPT customizado de análise
GPT_ANALYZER_LINK=https://chatgpt.com/g/g-seu-gpt-aqui

# Link do ChatGPT Go para geração de imagens
CHATGPT_GO_LINK=https://chatgpt.com

# OPCIONAL: Se quiser usar Stable Diffusion local
USE_LOCAL_GENERATION=false
STABLE_DIFFUSION_MODEL=runwayml/stable-diffusion-v1-5

# OPCIONAL: Configurações de qualidade
SHARPNESS_THRESHOLD=0.6
EXPOSURE_TOLERANCE=0.3
MAX_RETRIES=3